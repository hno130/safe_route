# Required only when you want live KOROAD data.
KOROAD_API_URL=
KOROAD_SERVICE_KEY=
KOROAD_YEAR=2024
KOROAD_SIDO=11
KOROAD_NUM_ROWS=100

# SQLite database for route history and public-data snapshot metadata.
SAFEWALK_DB_PATH=./safewalk.db

# auto: try OSMnx walking network first, then OSRM road routing, then grid
# road: use OSRM road routing, then fall back to grid if unavailable
# osmnx: require OSMnx and raise on routing failure
# grid: offline A* fallback only; it does not follow real streets
ROUTER_MODE=auto
OSRM_BASE_URL=https://router.project-osrm.org
OSRM_PROFILES=driving,foot,walking
SAFE_ROUTE_OPTION_COUNT=3
SAFE_ROUTE_CANDIDATE_POOL=14
SAFE_ROUTE_SIMILAR_DISTANCE_M=70
SAFE_ROUTE_SIMILAR_RATIO=0.72
SAFE_MAX_DETOUR_RATIO=1.25
SAFE_RISK_PENALTY_WEIGHT=2.8
SAFE_RISK_CORE_THRESHOLD=0.7
SAFE_RISK_CORE_PENALTY=90
SAFE_RISK_NEGATIVE_MULTIPLIER_SCALE=0.022
SAFE_FACILITY_POSITIVE_MULTIPLIER_SCALE=0.006
SAFE_RISK_CORE_BLOCK_THRESHOLD=0.85
SAFE_RISK_CORE_BLOCK_MULTIPLIER=35
SAFE_HIGH_RISK_THRESHOLD=25
SAFE_HIGH_RISK_TARGET_RATIO=0.45
SAFE_HIGH_RISK_MAX_DETOUR_RATIO=5.0
SAFE_HIGH_RISK_SOFT_DETOUR_RATIO=2.2
SAFE_HIGH_RISK_HARD_DETOUR_RATIO=3.0
SAFE_HIGH_RISK_DETOUR_PENALTY=170
SAFE_HIGH_RISK_DISTANCE_PENALTY=0.07
SAFEWALK_CACHE_DIR=../../work
OVERPASS_TIMEOUT=180

# Optional. If omitted, the app downloads Seoul Open Data streetlight CSV to SAFEWALK_CACHE_DIR.
SEOUL_STREETLIGHT_CSV=

# Optional route explanation generation.
# auto: use OpenAI when OPENAI_API_KEY exists, otherwise use the local template.
# template: never call OpenAI.
ROUTE_EXPLANATION_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_EXPLANATION_MODEL=gpt-5.5
OPENAI_TIMEOUT_SECONDS=8
